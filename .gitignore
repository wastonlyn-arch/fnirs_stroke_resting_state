# === Raw Data (never track — ~1GB binary) ===
rawData/
FX/
sourcedata/

# === BIDS symlinks (point to raw data) ===
bids/

# === Derivatives (MNE / Homer3 output folders) ===
derivatives/

# === fNIRS data files (too large) ===
*.nirs
*.snirf
*.mat

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# === Conda / Virtualenv ===
.env/
venv/
miniconda*/

# === IDE / Editor ===
.vscode/
.idea/

# === Output: large binary intermediates (regeneratable) ===
output/processed/*.npy
output/processed/*.pkl

# === OS junk ===
.DS_Store
Thumbs.db
*:Zone.Identifier

# === Secrets / Credentials ===
.env
*.secret

# === MATLAB temp files ===
*.asv

# === Large archives (keep on disk, not in git) ===
*.zip
*.tar
*.png
*.jpg

# === Log files ===
*.log

# === Claude internal ===
.claude/

# === Keep config files ===
!*.cfg
